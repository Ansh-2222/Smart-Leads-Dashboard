NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/smartleads
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
# Local dev: CORS_ORIGIN=http://localhost:5173
# Production (Render): set to your Vercel frontend URL (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173,https://your-vercel-app.vercel.app
